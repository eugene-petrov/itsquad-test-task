<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Pokédex</title>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="aeqet.pokedex.main"
                   template="Aeqet_Pokedex::pokedex.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">Aeqet\Pokedex\ViewModel\PokemonViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
