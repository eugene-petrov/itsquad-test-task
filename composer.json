{
    "name": "aeqet/magento2-module-pokedex",
    "description": "Pokédex frontend module for Magento 2 — search Pokémon by ID or name via PokéAPI",
    "type": "magento2-module",
    "license": [
        "proprietary"
    ],
    "authors": [
        {
            "name": "Aeqet",
            "email": "petroveugenv@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "magento/framework": "^103.0",
        "magento/module-store": "^101.1"
    },
    "require-dev": {
        "magento/magento-coding-standard": "^33",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Aeqet\\Pokedex\\": ""
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=Magento2 .",
        "phpcs-fix": "phpcbf --standard=Magento2 .",
        "phpstan": "phpstan analyse --no-progress"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
